# LINE チャネル（Messaging API）
# https://developers.line.biz/ でチャネルを作成し、以下を取得してください
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# OpenAI API
# https://platform.openai.com/api-keys でAPIキーを発行してください
OPENAI_API_KEY=

# Supabase（グループ課金状態の保存用）
# https://supabase.com でプロジェクト作成後、Settings > API から取得
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe（月額課金・プロモーションコード対応）
# https://dashboard.stripe.com/apikeys で取得。Checkout の success/cancel 用に公開URLが必要
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
BASE_URL=https://your-app.onrender.com

# 開発者専用の特権アクセス
# 自分のLINEユーザーID（個人チャットでも常にAI機能を利用可能）
ADMIN_USER_ID=
# テスト用に常にAI使い放題にしたいLINEグループID（カンマ区切りで複数指定可）
ADMIN_TEST_GROUP_IDS=
